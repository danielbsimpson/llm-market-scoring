# ===== LLM Market Scoring — environment configuration =====
# Copy to ".env" and adjust as needed. The .env file is git-ignored.

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Storage ----
# SQLite database file (relative to backend/ unless absolute)
DATABASE_URL=sqlite:///./data/app.db
# Directory for Parquet timeseries/feature files and raw article HTML
DATA_DIR=./data

# ---- LLM serving (reuses existing local install — no downloads) ----
# Provider: "ollama" (default) or "llama_server"
LLM_PROVIDER=ollama
# OpenAI-compatible base URL.
#   Ollama:        http://localhost:11434/v1
#   llama-server:  http://localhost:8080/v1  (start C:\llama.cpp\llama-server.exe -m <model> --port 8080)
LLM_BASE_URL=http://localhost:11434/v1
# API key is unused by local servers but the OpenAI client requires a non-empty value.
LLM_API_KEY=not-needed
# Default chat model for scoring (must exist in `ollama list`)
LLM_MODEL=qwen2.5:7b
# Embedding model (already pulled)
EMBED_MODEL=nomic-embed-text
# Context window to request
LLM_NUM_CTX=4096
# Sampling
LLM_TEMPERATURE=0.2

# ---- Local file ingestion ----
# Drop .eml / .html / .htm / .md files here for auto-detection.
# Mbox archives (.txt / .mbox) need an explicit --parser-key at the CLI / API.
INGEST_DIR=./data/inbox

# ---- Gmail ingestion (Phase 12 stretch goal — not yet implemented) ----
# Path to OAuth client secrets downloaded from Google Cloud Console
# GMAIL_CREDENTIALS_FILE=./secrets/credentials.json
# GMAIL_TOKEN_FILE=./secrets/token.json
# Sender to filter when querying for the newsletter
# GMAIL_SNACK_SENDER=

# ---- Market data ----
# Forward return windows in trading days: 1d, 1w(=5), 1m(=21), 3m(=63)
RETURN_WINDOWS=1,5,21,63

# ---- Frontend ----
# Base URL the React app uses to reach the backend
VITE_API_BASE_URL=http://localhost:8000
